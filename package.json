{
  "name": "aexs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-docs": "mkdir -p public/docs && cp docs/business-contradictions.md public/docs/business-contradictions.md",
    "predev": "npm run sync-docs",
    "prebuild": "npm run sync-docs",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "check-docs-sync": "test -f public/docs/business-contradictions.md || (echo 'ERROR: public/docs/business-contradictions.md is missing. Run: npm run sync-docs' && exit 1) && diff docs/business-contradictions.md public/docs/business-contradictions.md",
    "prepare": "git config core.hooksPath .githooks",
    "verify-theme-sync": "node scripts/verify-theme-sync.js",
    "export-deck": "node scripts/export-deck-pdf.js",
    "check": "eslint . && vitest run && npm run build && npm run check-docs-sync && npm run verify-theme-sync"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}

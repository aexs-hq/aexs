#!/bin/sh
# AEXS pre-commit hook.
# Install (one-time per clone): npm run setup-hooks
#   (equivalent to: git config core.hooksPath .githooks)
#
# Guards enforced here are the ones that must never ship a broken commit:
#   1. Content consistency across JSX and Python rendering code (ADR-004).

set -e
npm run verify-content-consistency
